<!doctype html><html lang="pt-BR"><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Atualizando JB3D Vendas</title><body style="font-family:system-ui;background:#080d18;color:#fff;display:grid;place-items:center;min-height:100vh;text-align:center"><div><h2>Atualizando o aplicativo…</h2><p>O cache antigo está sendo removido.</p></div><script>Promise.all([navigator.serviceWorker?navigator.serviceWorker.getRegistrations().then(rs=>Promise.all(rs.map(r=>r.unregister()))):null,caches?caches.keys().then(ks=>Promise.all(ks.map(k=>caches.delete(k)))):null]).finally(()=>location.replace('./?v=3.3.0'));</script></body></html>
